# consensus-rnd-spec host configuration

# Required for unattended runs.
export REPO_ROOT="/abs/path/to/host-repo"

# Optional native compatibility surface. consensus-rnd-spec itself does not
# create/comment/close GitHub issues; native codex-refactor-loop may require it
# after NATIVE_FULL_LOOP_ENABLE=true.
export GH_REPO_SLUG="OWNER/REPO"

# Backend selection: auto | spec-kitty | native
export BACKEND_MODE="auto"

# Keep at least this many host-scoped workers in flight.
export CODEX_FLOOR="5"
export LOOP_INTERVAL_SECONDS="600"

# Spec Kitty backend defaults.
export SPEC_KITTY_AGENT="codex"
export SPEC_KITTY_MISSION_TYPE="software-dev"
export SPEC_KITTY_FULL_LOOP_ENABLE="true"
# Optional. When empty, the adapter chooses the first mission with ready work.
export SPEC_KITTY_MISSION=""
export SPEC_KITTY_SCAN_LIMIT="30"

# Codex worker options used by run_loop.py --execute.
export CODEX_MODEL=""
export CODEX_EXTRA_ARGS=""

# Native fallback is intentionally explicit because it can open PRs, merge, and close issues.
export NATIVE_FULL_LOOP_ENABLE="false"
# Points at an installed ChronoAIProject/consensus-rnd codex-refactor-loop skill.
# The adapter discovers either legacy consensus-rnd-cli or current spawn-codex.sh at runtime.
export NATIVE_CONSENSUS_SKILL_ROOT="/abs/path/to/skills/codex-refactor-loop"

# Synthetic intake may produce Human: ... prompts, but never maintainer approval.
export SYNTHETIC_HUMAN_INTAKE_ENABLE="true"
